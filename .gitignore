# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — use config/deployment.env locally (gitignored)
.env*
!config/deployment.env.example

# local secrets copy (never commit)
config/deployment.env
scripts/create-admin-user.sql

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
