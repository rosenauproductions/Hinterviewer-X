# Hinterviewer-X deployment config
#
# 1. Pick client id from clients/registry.json
# 2. Create Supabase project for that client; add supabaseProjectRef to registry
# 3. Set vars below (local: cp to .env.local | Netlify: Site env vars)

# Required — which client is THIS site?
NEXT_PUBLIC_CLIENT_ID=msc1

# Required — secrets from Supabase → Settings → API (this client's project only)
# Use the legacy JWT keys (long eyJ... strings). Do NOT leave "..." or example text.
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE_FULL_ANON_JWT_FROM_SUPABASE_HERE
SUPABASE_SERVICE_ROLE_KEY=PASTE_FULL_SERVICE_ROLE_JWT_FROM_SUPABASE_HERE

# Optional if supabaseProjectRef is in registry for this client:
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

NEXT_PUBLIC_DEPLOYMENT_ENV=production
