{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hinterviewer client registry",
  "type": "object",
  "required": ["clients"],
  "properties": {
    "clients": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "supabaseProjectRef": {
            "type": "string",
            "description": "Supabase project ref (subdomain). Public, not secret. URL = https://{ref}.supabase.co"
          },
          "logoUrl": { "type": "string" },
          "primaryColor": { "type": "string" },
          "secondaryColor": { "type": "string" },
          "netlifySiteHint": {
            "type": "string",
            "description": "Suggested Netlify site name when creating a new deploy"
          }
        }
      }
    }
  }
}
