# Example client environment configuration
# Copy this file and customize for each client

# Supabase Configuration (Required - get from Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://example-client.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Client Branding (Optional)
NEXT_PUBLIC_CLIENT_NAME=Example Corp
NEXT_PUBLIC_CLIENT_LOGO_URL=/logos/example-corp.png
NEXT_PUBLIC_CLIENT_PRIMARY_COLOR=#ff6b35
NEXT_PUBLIC_CLIENT_SECONDARY_COLOR=#f7931e
NEXT_PUBLIC_CLIENT_ID=example-corp

# Deployment Info
NEXT_PUBLIC_DEPLOYMENT_ENV=production
NEXT_PUBLIC_VERCEL_ANALYTICS=true
