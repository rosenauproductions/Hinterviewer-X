{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_CLIENT_NAME": "@client-name",
    "NEXT_PUBLIC_CLIENT_LOGO_URL": "@client-logo-url",
    "NEXT_PUBLIC_CLIENT_PRIMARY_COLOR": "@client-primary-color",
    "NEXT_PUBLIC_CLIENT_SECONDARY_COLOR": "@client-secondary-color",
    "NEXT_PUBLIC_DEPLOYMENT_ENV": "production",
    "NEXT_PUBLIC_CLIENT_ID": "@client-id",
    "NEXT_PUBLIC_VERCEL_ANALYTICS": "true"
  }
}
